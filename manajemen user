#include <iostream>
#include <vector>
using namespace std;

// ===== Base Class =====
class user {
protected:
    static int globalId;
    int id;
    string nama;
    string email;

public:
    user(string pNama, string pEmail) : nama(pNama), email(pEmail) {
        id = generateId();
    }

    static int generateId() {
        return ++globalId;
    }

    int getId() { return id; }
    string getNama() { return nama; }
    string getEmail() { return email; }
};

